# Copy to .env and fill in values:
#   cp .env.example .env

# Server
PORT=5000
NODE_ENV=development

# Database (required)
MONGODB_URI=mongodb://localhost:27017/sigmora

# JWT (required)
# Generate: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Payments (Flutterwave) — required for payment routes
# https://dashboard.flutterwave.com/ → Settings → API Keys
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your-test-secret-key-here

# Frontend (CORS, payment redirects, password reset links)
FRONTEND_URL=http://localhost:3005

# Extra CORS origins (comma-separated), e.g. preview URLs or custom domains
# ALLOWED_ORIGINS=https://sigmora.com,https://www.sigmora.com

# Vercel cron (auto-set by Vercel in production; optional locally)
# CRON_SECRET=

# Password reset: in development, POST /api/auth/forgot-password returns resetUrl in the response
